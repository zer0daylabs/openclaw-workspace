# Ringo Backend Environment Variables

## Database
DATABASE_URL="postgresql://user:password@localhost:5432/ringo?schema=public"

## Redis
REDIS_URL="redis://localhost:6379"
REDIS_TTL_ROUTING=10
REDIS_TTL_AI=60

## JWT Authentication
JWT_SECRET="your-secret-key-change-in-production"
JWT_EXPIRES_IN="7d"

## Stripe
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
PLATFORM_FEE_PERCENT=10

## AI Service
AI_SERVICE_URL="https://ai-service.ringo.internal"
AI_SERVICE_API_KEY="your_ai_service_api_key"

## Telephony
TELEPHONY_WEBHOOK_SECRET="your_telephony_webhook_secret"

## Logging
LOG_LEVEL="info"
SENTRY_DSN="your_sentry_dsn"

## Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

## Server
NODE_ENV="development"
PORT=3000
