# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ringo?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Stripe
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
STRIPE_PRODUCT_PRICE_ID="price_your_product_price_id"

# LLM Configuration
LLM_API_URL="https://api.you-llm-provider.com/v1"
LLM_API_KEY="your-llm-api-key"
LLM_MODEL="gpt-4-turbo"

# AWS S3 (for call recordings)
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_S3_BUCKET="ringo-call-recordings"
AWS_REGION="us-east-1"

# Environment
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
